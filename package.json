{
  "name": "party-game-pass-and-play",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:lobby": "tsx watch server/index.ts",
    "dev:all": "concurrently -n lobby,vite -c magenta,cyan \"npm run dev:lobby\" \"npm run dev\"",
    "build": "vite build",
    "build:production": "node scripts/build-production.mjs",
    "build:server": "node scripts/bundle-server.mjs",
    "verify:dist": "node scripts/verify-dist.mjs",
    "build:electron-host": "cross-env VITE_VALORUSH_CLIENT=host vite build",
    "build:electron-join": "cross-env VITE_VALORUSH_CLIENT=join vite build --base ./",
    "start": "tsx server/index.ts",
    "start:prod": "node dist-server/index.cjs",
    "start:prod:full": "npm run build:production && npm run start:prod",
    "preview": "vite preview",
    "type-check": "tsc --noEmit && tsc --noEmit -p server/tsconfig.json",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:jsdom": "vitest --env=jsdom",
    "package:win:host": "npm run build:electron-host && npm run build:server && cross-env VALORUSH_MODE=host electron-builder --win --config electron/builder.host.cjs",
    "package:win:join": "npm run build:electron-join && cross-env VALORUSH_MODE=join electron-builder --win --config electron/builder.join.cjs",
    "package:win": "npm run package:win:join"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.7",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.2",
    "typescript": "^5.2.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "build": {
    "extends": "electron/builder.base.cjs"
  }
}
