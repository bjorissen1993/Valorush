# Twitch app credentials — https://dev.twitch.tv/console/apps
VITE_TWITCH_CLIENT_ID=
VITE_TWITCH_CLIENT_SECRET=

# Optional: only needed when frontend and lobby WebSocket are on different hosts.
# Dev/tunnel with one URL can leave this unset (defaults to same host /ws).
# VITE_LOBBY_WS_URL=wss://your-tunnel.example.com/ws
#
# If the browser shows repeated WebSocket failures on production, clear any stale
# dev override: localStorage.removeItem("valorush_lobby_ws_url") then reload.

# Optional: override OAuth redirect when Twitch console needs an exact URL.
# Defaults to window.location.origin + "/" (works for ngrok / LAN if registered).
# VITE_TWITCH_REDIRECT_URI=https://your-tunnel.example.com/

# Optional: lobby server port (default 3001). Used by server and Vite /ws proxy.
# LOBBY_PORT=3001

# --- Desktop packaging (npm run package:win:*) ---
# Joiner builds: set your public lobby WebSocket URL before packaging.
# Example: wss://your-tunnel.ngrok-free.app/ws
# VITE_LOBBY_WS_URL=wss://your-tunnel.ngrok-free.app/ws
# VITE_VALORUSH_CLIENT=join

# Host builds: set Twitch creds above, then npm run package:win:host
# Optional: place .env.local in %APPDATA%/ValoRush Host/ after install instead of baking secrets.
# VITE_VALORUSH_CLIENT=host

# Optional for static builds without server-side Twitch proxy:
# VITE_TWITCH_ACCESS_TOKEN=
